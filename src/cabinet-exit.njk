<!DOCTYPE html>
<html lang="ru">

<head>
    <title>Личный кабинет - вход</title>
    {% include 'blocks/head.njk' %}
</head>

<body class="preload mp">
    <div class="main-wrapper-outer">
        {% include 'blocks/header-black.njk' %}
        <main class="main">

            <div class="cabinet">
                <div class="container">
                    <div class="cabinet-auth">
                        <div class="cabinet-auth__image">
                            <img src="img/image20.webp" alt="">
                        </div>
                        <div class="cabinet-auth__body">
                            <div class="cabinet-auth__top">
                                <div class="cabinet-auth__titles">
                                    <div class="cabinet-auth__title">
                                        WELCOME BACK
                                    </div>
                                    <div class="cabinet-auth__text">
                                        <p>
                                            Login to Your Account
                                        </p>
                                        <p>
                                            Don't have an account?
                                            <a href="./">Register</a>
                                        </p>
                                    </div>
                                </div>
                            </div>
                            <form action="#" class="form">
                                <div class="form__inputs">
                                    <div class="form__input">
                                        <label for="email">Email</label>
                                        <input id="email" data-required autocomplete="off" type="text" name="form[]"
                                            placeholder="Email">
                                    </div>
                                    <div class="form__input">
                                        <label for="password">Password</label>
                                        <input id="password" data-required autocomplete="off" type="password" name="form[]"
                                            placeholder="Password">
                                    </div>
                                </div>
                                <div class="form__bottom">
                                    <button type="submit" class="btn-custom btn-brown">SIGN IN</button>
                                    <a href="./" class="form__forgot-password">Forgot password?</a>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>

        </main>
        {% include 'blocks/footer.njk' %}
    </div>
    {% include 'blocks/popups.njk' %}
    {% include 'blocks/scripts.njk' %}
</body>

</html>