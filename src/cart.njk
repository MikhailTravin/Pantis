<!DOCTYPE html>
<html lang="ru">

<head>
    <title>Корзина</title>
    {% include 'blocks/head.njk' %}
</head>

<body class="preload mp">
    <div class="main-wrapper-outer">
        {% include 'blocks/header-black.njk' %}
        <main class="main">

            <div class="cart cart-fixed">
                <div class="container">
                    <div class="cart__content d-flex position-relative">
                        <div class="cart-details cart-details-fixed">
                            <div class="cart-details__body d-flex flex-column">
                                <div class="cart-details__title d-lg-block d-none">
                                    CART
                                </div>
                                <div class="cart-details__totals">
                                    <div class="cart-details__subtotal">
                                        <span>Subtotal</span>
                                        <div class="cart-details__subtotal-summ text-right">10 000 RUS</div>
                                    </div>
                                    <div class="cart-details__info desc">
                                        <div class="cart-details__name small">
                                            Stockings
                                            <span>Pink,One size</span>
                                        </div>
                                        <div class="cart-details__quantity small text-center">1</div>
                                        <div class="cart-details__summ text-right">
                                            10 000 RUB
                                        </div>
                                    </div>
                                    <div class="cart-details__info">
                                        <div class="cart-details__name small">
                                            Total
                                        </div>
                                        <div class="cart-details__summ text-right">
                                            10 000 RUB
                                        </div>
                                    </div>
                                </div>
                                <div class="cart-details__bottom d-flex flex-column">
                                    <a href="./" class="btn-custom btn-brown text-uppercase w-100">PROCEED TO
                                        CHECKOUT</a>
                                    <div class="cart-details__text text-center">
                                        By proceeding, you agree to our Terms & Conditions
                                    </div>
                                </div>
                            </div>
                        </div>
