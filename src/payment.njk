<!DOCTYPE html>
<html lang="ru">

<head>
    <title>Оплата</title>
    {% include 'blocks/head.njk' %}
</head>

<body class="preload mp">
    <div class="main-wrapper-outer">
        {% include 'blocks/header-black.njk' %}
        <main class="main">

            <div class="cart">
                <div class="container">
                    <div class="cart__content d-flex position-relative">
                        <div class="cart-details">
                            <div class="cart-details__body d-flex flex-column">
                                <div class="cart-details__title">
                                    Payment Method
                                </div>
                                <form action="#" class="cart-details__payments d-flex flex-column">
                                    <div class="cart-details__payment d-flex flex-column">
                                        <button type="button" class="cart-details__button button-card d-flex">
                                            <img src="img/icons/card.svg" alt="">
                                            <span>Bank Card</span>
                                        </button>
                                        <div class="form-column flex-column mb-5 mb-md-5">
                                            <div class="form-row">
                                                <div>
                                                    <label for="card-number" class="form-label">Card Number</label>
                                                    <input type="text" class="form-control card-number" id="card-number"
                                                        placeholder="XXXX XXXX XXXX XXXX" data-required>
                                                </div>
                                                <div>
                                                    <label for="card-name" class="form-label">Cardholder Name</label>
                                                    <input type="text" class="form-control" id="name" placeholder="Name"
                                                        data-required class="text-uppercase">
                                                </div>
                                            </div>
                                            <div class="form-row">
                                                <div>
                                                    <label for="card-data" class="form-label">Expiry Date</label>
                                                    <input type="text" class="form-control card-data" id="card-data"
                                                        placeholder="00/00" data-required>
                                                </div>
                                                <div>
                                                    <label for="card-cvc" class="form-label">CVV</label>
                                                    <input type="text" class="form-control card-cvc" id="card-cvc"
                                                        placeholder="999" data-required>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="cart-details__payment">
                                        <a href="./" class="cart-details__button">
                                            <img src="img/icons/spb.svg" alt="">
                                            <span>СБП</span>
                                        </a>
                                    </div>
                                    <div class="form-bottom flex-column">
                                        <button type="submit" class="btn-custom btn-brown w-100 disabled">PAY
                                            NOW</button>
                                        <a href="./" class="form-text text-center">
                                            By proceeding, you agree to our Terms & Conditions
                                        </a>
                                    </div>
                                </form>
                            </div>
                        </div>
                        <div class="cart__body">
                            <div class="cart__cards d-flex flex-column">
                                <div class="card-cart d-flex gap-3">
                                    <a href="./" class="card-cart__image">
                                        <img loading="lazy" src="img/product1.webp" alt="">
                                    </a>
                                    <div class="card-cart__body d-flex flex-column justify-content-between">
                                        <a href="./" class="card-cart__title">SUBTOTAL</a>
                                        <div class="card-cart__item d-flex justify-content-between align-items-end">
                                            <div class="card-cart__left d-flex flex-column">
                                                <div class="card-cart__info small">Pink, One size
                                                </div>
                                                <div class="card-cart__price">10 000 RUS</div>
                                            </div>
                                            <div data-quantity
                                                class="quantity d-flex align-items-center justify-content-center">
                                                <button data-quantity-minus type="button"
                                                    class="quantity__button quantity__button_minus d-flex align-items-center justify-content-center text-center text-uppercase">-</button>
                                                <div class="quantity__input">
                                                    <input data-quantity-value autocomplete="off" type="text"
                                                        name="form[]" value="1" class="text-uppercase text-center">
                                                </div>
                                                <button data-quantity-plus type="button"
                                                    class="quantity__button quantity__button_plus d-flex align-items-center justify-content-center text-center text-uppercase">+</button>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="card-cart d-flex gap-3">
                                    <a href="./" class="card-cart__image">
                                        <img loading="lazy" src="img/product1.webp" alt="">
                                    </a>
                                    <div class="card-cart__body d-flex flex-column justify-content-between">
                                        <a href="./" class="card-cart__title">SUBTOTAL</a>
                                        <div class="card-cart__item d-flex justify-content-between align-items-end">
                                            <div class="card-cart__left d-flex flex-column">
                                                <div class="card-cart__info small">Pink, One size
                                                </div>
                                                <div class="card-cart__price">10 000 RUS</div>
                                            </div>
                                            <div data-quantity
                                                class="quantity d-flex align-items-center justify-content-center">
                                                <button data-quantity-minus type="button"
                                                    class="quantity__button quantity__button_minus d-flex align-items-center justify-content-center text-center text-uppercase">-</button>
                                                <div class="quantity__input">
                                                    <input data-quantity-value autocomplete="off" type="text"
                                                        name="form[]" value="1" class="text-uppercase text-center">
                                                </div>
                                                <button data-quantity-plus type="button"
                                                    class="quantity__button quantity__button_plus d-flex align-items-center justify-content-center text-center text-uppercase">+</button>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="card-cart d-flex gap-3">
                                    <a href="./" class="card-cart__image">
                                        <img loading="lazy" src="img/product1.webp" alt="">
                                    </a>
                                    <div class="card-cart__body d-flex flex-column justify-content-between">
                                        <a href="./" class="card-cart__title">SUBTOTAL</a>
                                        <div class="card-cart__item d-flex justify-content-between align-items-end">
                                            <div class="card-cart__left d-flex flex-column">
                                                <div class="card-cart__info small">Pink, One size
                                                </div>
                                                <div class="card-cart__price">10 000 RUS</div>
                                            </div>
                                            <div data-quantity
                                                class="quantity d-flex align-items-center justify-content-center">
                                                <button data-quantity-minus type="button"
                                                    class="quantity__button quantity__button_minus d-flex align-items-center justify-content-center text-center text-uppercase">-</button>
                                                <div class="quantity__input">
                                                    <input data-quantity-value autocomplete="off" type="text"
                                                        name="form[]" value="1" class="text-uppercase text-center">
                                                </div>
                                                <button data-quantity-plus type="button"
                                                    class="quantity__button quantity__button_plus d-flex align-items-center justify-content-center text-center text-uppercase">+</button>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="card-cart d-flex gap-3">
                                    <a href="./" class="card-cart__image">
                                        <img loading="lazy" src="img/product1.webp" alt="">
                                    </a>
                                    <div class="card-cart__body d-flex flex-column justify-content-between">
                                        <a href="./" class="card-cart__title">SUBTOTAL</a>
                                        <div class="card-cart__item d-flex justify-content-between align-items-end">
                                            <div class="card-cart__left d-flex flex-column">
                                                <div class="card-cart__info small">Pink, One size
                                                </div>
                                                <div class="card-cart__price">10 000 RUS</div>
                                            </div>
                                            <div data-quantity
                                                class="quantity d-flex align-items-center justify-content-center">
                                                <button data-quantity-minus type="button"
                                                    class="quantity__button quantity__button_minus d-flex align-items-center justify-content-center text-center text-uppercase">-</button>
                                                <div class="quantity__input">
                                                    <input data-quantity-value autocomplete="off" type="text"
                                                        name="form[]" value="1" class="text-uppercase text-center">
                                                </div>
                                                <button data-quantity-plus type="button"
                                                    class="quantity__button quantity__button_plus d-flex align-items-center justify-content-center text-center text-uppercase">+</button>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

        </main>
    </div>
    {% include 'blocks/popups.njk' %}
    <script src="js/inputmask.min.js"></script>
    {% include 'blocks/scripts.njk' %}
    <script>
        const cardNumber = document.querySelectorAll('.card-number');
        if (cardNumber) {
            Inputmask({
                "mask": "9999 9999 9999 9999",
                "showMaskOnHover": false,
            }).mask(cardNumber);
        }
        const cardData = document.querySelectorAll('.card-data');
        if (cardData) {
            Inputmask({
                "mask": "99/99",
                "showMaskOnHover": false,
            }).mask(cardData);
        }
        const cardCvc = document.querySelectorAll('.card-cvc');
        if (cardCvc) {
            Inputmask({
                "mask": "999",
                "showMaskOnHover": false,
            }).mask(cardCvc);
        }
    </script>
</body>

</html>